root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# The evidence-map CSV intentionally uses CRLF; don't let editors rewrite it.
[*.csv]
end_of_line = crlf
trim_trailing_whitespace = false

[*.md]
trim_trailing_whitespace = false
