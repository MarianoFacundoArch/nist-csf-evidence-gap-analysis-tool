# ---------------------------------------------------------------------------
# Environment template for the NIST CSF 2.0 AI-Assisted Evidence & Gap tool.
#
# Copy this file to ".env" and fill in only the values you need. The .env file
# is for SECRETS and ENDPOINTS ONLY (API keys, server hosts). All behavioral
# settings (providers, models, top-k, thresholds, chunking) live in the JSON
# config file (csf-tool.config.json), not here.
#
# The .env file is git-ignored. Never commit real keys.
# ---------------------------------------------------------------------------

# OpenAI — required only when using the "openai" embeddings or LLM provider
# (which is the default, cloud-first configuration). If you run fully offline
# with `--local`, you do not need this.
OPENAI_API_KEY=
# Optional: point the OpenAI client at an OpenAI-compatible gateway/proxy.
OPENAI_BASE_URL=

# Ollama — required only when using the fully-local "ollama" LLM/embeddings
# provider (e.g. under `--local`). Defaults to the standard local daemon.
OLLAMA_HOST=http://127.0.0.1:11434
